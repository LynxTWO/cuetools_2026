<!--
  Lit panel toggle - the reference implementation for the lit-panel-controls skill.

  A physical switch: a bulb behind translucent plastic. OFF = dark housing + cap on the left.
  ON = the bulb lights the EXPOSED plastic (lit lens on the left when the cap is on the right),
  falls off to dark under the cap, and a little light bleeds through the thick plastic cap.

  ONE KNOB - the light color. Only the five emissive colors below carry the hue; the housing,
  cap metal, and occlusion (pure black) never change. To recolor, replace these five wherever
  they appear (glow gradient + cap-bleed gradient + the two DropShadowEffect Colors), keeping the
  offsets and alphas. Cap-bleed colors reuse the same hues with alpha prefixes (e.g. #B8<core>).

  Role         Teal (below)   Amber       Green
  Core         EAFFFB         FFF6E9      EAFFF1
  Light tint   6FE3D6         F0C784      9FE9B8
  Base accent  34CFC0/27A99C  E9A63F      5CCB8B
  Dark accent  0E4F48         7A5416      1E5E38
  Edge (dark)  06211E         241804      06210F

  Tune it by rendering to PNG (see the skill's "Verify by rendering" section), not by guessing.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="Switch" TargetType="ToggleButton">
    <Setter Property="Width" Value="50"/>
    <Setter Property="Height" Value="25"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid>
            <!-- 1. housing: recessed translucent plastic (neutral - never carries the hue) -->
            <Border x:Name="housing" CornerRadius="12" BorderThickness="1" BorderBrush="#0A0F0B">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#0A0E0B" Offset="0"/>
                  <GradientStop Color="#131A14" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>

            <!-- 2. lens glow: bulb through the EXPOSED plastic; hotspot on the exposed side,
                 falloff to dark under the cap. Carries the light color. -->
            <Border x:Name="glow" CornerRadius="12" Opacity="0" Margin="1">
              <Border.Background>
                <RadialGradientBrush GradientOrigin="0.3,0.5" Center="0.3,0.5" RadiusX="0.72" RadiusY="1.15">
                  <GradientStop Color="#EAFFFB" Offset="0"/>
                  <GradientStop Color="#6FE3D6" Offset="0.26"/>
                  <GradientStop Color="#27A99C" Offset="0.52"/>
                  <GradientStop Color="#0E4F48" Offset="0.78"/>
                  <GradientStop Color="#06211E" Offset="1"/>
                </RadialGradientBrush>
              </Border.Background>
            </Border>

            <!-- 3. occlusion: soft black shadow the cap casts on the lit plastic (neutral) -->
            <Border x:Name="occlude" Width="23" Height="21" CornerRadius="6" HorizontalAlignment="Left" Margin="1,0,0,0" Opacity="0">
              <Border.Background>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.62" RadiusY="0.62">
                  <GradientStop Color="#73000000" Offset="0"/>
                  <GradientStop Color="#3C000000" Offset="0.65"/>
                  <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
              </Border.Background>
            </Border>

            <!-- cap: thick beveled dark plastic (neutral) -->
            <Border x:Name="thumb" Width="21" Height="19" CornerRadius="5" HorizontalAlignment="Left" Margin="2,0,0,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#5A6356" Offset="0"/>
                  <GradientStop Color="#333C34" Offset="0.5"/>
                  <GradientStop Color="#242B25" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="1.5" Direction="270" Opacity="0.55"/>
              </Border.Effect>
            </Border>

            <!-- 4. cap bleed: light through the thick plastic cap, strongest on the lens-facing
                 edge, faint. Carries the light color (alpha-prefixed). -->
            <Border x:Name="capBleed" Width="21" Height="19" CornerRadius="5" HorizontalAlignment="Left" Margin="2,0,0,0" Opacity="0">
              <Border.Background>
                <RadialGradientBrush GradientOrigin="0.1,0.62" Center="0.1,0.62" RadiusX="0.95" RadiusY="1.0">
                  <GradientStop Color="#B8F1FBF9" Offset="0"/>
                  <GradientStop Color="#5A45D6C9" Offset="0.35"/>
                  <GradientStop Color="#0034CFC0" Offset="0.9"/>
                </RadialGradientBrush>
              </Border.Background>
            </Border>

            <!-- specular sheen along the cap top (neutral) -->
            <Border x:Name="sheen" Width="15" Height="3" CornerRadius="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5,3,0,0" Background="#26FFFFFF"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="glow" Property="Opacity" Value="1"/>
              <Setter TargetName="occlude" Property="Opacity" Value="1"/>
              <Setter TargetName="occlude" Property="HorizontalAlignment" Value="Right"/>
              <Setter TargetName="occlude" Property="Margin" Value="0,0,1,0"/>
              <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
              <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
              <Setter TargetName="capBleed" Property="Opacity" Value="0.5"/>
              <Setter TargetName="capBleed" Property="HorizontalAlignment" Value="Right"/>
              <Setter TargetName="capBleed" Property="Margin" Value="0,0,2,0"/>
              <Setter TargetName="sheen" Property="HorizontalAlignment" Value="Right"/>
              <Setter TargetName="sheen" Property="Margin" Value="0,3,5,0"/>
              <!-- outer housing glow in the light color -->
              <Setter TargetName="housing" Property="Effect">
                <Setter.Value><DropShadowEffect Color="#34CFC0" BlurRadius="12" ShadowDepth="0" Opacity="0.55"/></Setter.Value>
              </Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
