<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Accent colors (same in both themes). The THEMEABLE structural brushes - Ground, Bar, Face,
       Panel, Line, Ink, InkDim, Muted, Glass, GlassLine, ButtonPressed, ButtonFace - are NOT
       defined here: ThemeService creates them as single mutable brush objects in the app resources
       and recolors them on light/dark toggle, so every DynamicResource consumer updates from the
       one brush (no ambiguous frozen duplicate to fight). -->
  <SolidColorBrush x:Key="Teal"     Color="#34CFC0"/>
  <SolidColorBrush x:Key="Teal2"    Color="#46B8E0"/>
  <SolidColorBrush x:Key="Amber"    Color="#E9A63F"/>
  <SolidColorBrush x:Key="Good"     Color="#5CCB8B"/>
  <SolidColorBrush x:Key="TealSoft" Color="#2434CFC0"/>

  <!-- Switch "bulb" colors as a one-knob ramp (see the lit-panel-controls skill). The Switch
       template references these via DynamicResource, so a settings section can color-code its
       switches by overriding these Color keys in its own Resources scope. Default = teal. -->
  <Color x:Key="LampCore">#EAFFFB</Color>
  <Color x:Key="LampLight">#6FE3D6</Color>
  <Color x:Key="LampBase">#27A99C</Color>
  <Color x:Key="LampDark">#0E4F48</Color>
  <Color x:Key="LampEdge">#06211E</Color>
  <Color x:Key="LampHalo">#34CFC0</Color>
  <Color x:Key="LampCapCore">#B8F1FBF9</Color>
  <Color x:Key="LampCapMid">#5A45D6C9</Color>
  <Color x:Key="LampCapEdge">#0034CFC0</Color>

  <!-- Lead each stack with a font that ships on every Windows and is unlikely to have a broken
       font-cache entry (Cascadia Mono was found broken on a test machine, throwing FileNotFoundException
       in DWrite and aborting the whole window). The nicer faces stay as fallbacks. -->
  <FontFamily x:Key="Serif">Sitka Text, Cambria, Georgia, serif</FontFamily>
  <FontFamily x:Key="Mono">Consolas, Cascadia Mono, monospace</FontFamily>

  <!-- Panel button: reads like a milled bench-gear key. Dark brushed face, hairline edge that
       lights teal on hover, sinks on press. Implicit, so every plain Button picks it up. -->
  <Style TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="BorderBrush" Value="{DynamicResource GlassLine}"/>
    <Setter Property="Background" Value="{DynamicResource ButtonFace}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" CornerRadius="7" BorderThickness="1"
                  Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Teal}"/>
              <Setter TargetName="b" Property="Effect">
                <Setter.Value><DropShadowEffect Color="#34CFC0" BlurRadius="9" ShadowDepth="0" Opacity="0.4"/></Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="b" Property="Background" Value="{DynamicResource ButtonPressed}"/>
              <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Line}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="b" Property="Opacity" Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Accent button for the primary action on a page (Rip, Verify, Convert). Teal-lit lens. -->
  <Style x:Key="Accent" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Foreground" Value="#04110F"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="BorderBrush" Value="{StaticResource Teal}"/>
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#5FE0D3" Offset="0"/>
          <GradientStop Color="#2FC2B4" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- dark dropdown to match the panel buttons -->
  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="5">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource TealSoft}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Height" Value="30"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="tb" Focusable="False" ClickMode="Press"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="face" CornerRadius="7" BorderThickness="1" BorderBrush="{DynamicResource GlassLine}" Background="{DynamicResource ButtonFace}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="22"/>
                      </Grid.ColumnDefinitions>
                      <!-- force the selected-item text colour: this ContentPresenter lives inside a
                           plain ToggleButton whose default style sets Foreground=black, which would
                           otherwise beat the ComboBox's inherited Ink and render black on dark. -->
                      <ContentPresenter Grid.Column="0" Margin="11,0,0,0" VerticalAlignment="Center"
                                        TextElement.Foreground="{DynamicResource Ink}"
                                        Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                      <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Data="M0,0 L8,0 L4,5 Z" Fill="{DynamicResource Muted}"/>
                    </Grid>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="face" Property="BorderBrush" Value="{StaticResource Teal}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
              <Border Margin="0,4,0,0" CornerRadius="8" Background="{DynamicResource Face}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1"
                      MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" Padding="4">
                <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="3" Opacity="0.5"/></Border.Effect>
                <ScrollViewer MaxHeight="260"><ItemsPresenter/></ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- list column headers (Rip track list, Verify/Queue source lists) - themed, replacing the
       default white system header that read as a white bar on the dark surface. -->
  <Style TargetType="GridViewColumnHeader">
    <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
    <Setter Property="Background" Value="{DynamicResource Bar}"/>
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Padding" Value="9,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GridViewColumnHeader">
          <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,1" Padding="{TemplateBinding Padding}">
            <ContentPresenter TextElement.Foreground="{DynamicResource Muted}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- left-nav item -->
  <Style x:Key="NavItem" TargetType="ListBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource InkDim}"/>
    <Setter Property="Padding" Value="12,9"/>
    <Setter Property="Margin" Value="0,1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="b" Background="Transparent" CornerRadius="9" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="Background" Value="{DynamicResource Panel}"/>
              <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource TealSoft}"/>
              <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Physical lit toggle. A translucent plastic housing with a bulb behind it. OFF: dark, cap
       left. ON: the bulb lights the exposed plastic (lit lens on the left), the light bleeds
       faintly through the cap, and the cap slides right. The transition is animated with real
       physics: the cap snaps across (slight mechanical overshoot), the bulb WARMS UP quickly, and
       on OFF it COOLS DOWN with a longer dim tail like an incandescent filament. The cap parts
       ride together in a translated "mover"; the lens opacity carries the warm/cool curve. -->
  <Style x:Key="Switch" TargetType="ToggleButton">
    <Setter Property="Width" Value="50"/>
    <Setter Property="Height" Value="25"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid>
            <!-- housing: recessed translucent plastic (fixed) -->
            <Border x:Name="housing" CornerRadius="12" BorderThickness="1" BorderBrush="#0A0F0B">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#0A0E0B" Offset="0"/>
                  <GradientStop Color="#131A14" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>

            <!-- bulb glow behind the plastic (lit lens on the left) + the outer teal halo, both
                 carried by this layer's Opacity (0 off, warms to 1 on). -->
            <Border x:Name="glow" CornerRadius="12" Opacity="0" Margin="1">
              <Border.Background>
                <RadialGradientBrush GradientOrigin="0.3,0.5" Center="0.3,0.5" RadiusX="0.72" RadiusY="1.15">
                  <GradientStop Color="{DynamicResource LampCore}" Offset="0"/>
                  <GradientStop Color="{DynamicResource LampLight}" Offset="0.26"/>
                  <GradientStop Color="{DynamicResource LampBase}" Offset="0.52"/>
                  <GradientStop Color="{DynamicResource LampDark}" Offset="0.78"/>
                  <GradientStop Color="{DynamicResource LampEdge}" Offset="1"/>
                </RadialGradientBrush>
              </Border.Background>
              <Border.Effect><DropShadowEffect Color="{DynamicResource LampHalo}" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
            </Border>

            <!-- mover: the cap and everything riding with it, translated on toggle -->
            <Grid x:Name="mover" Width="21" Height="19" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
              <Grid.RenderTransform><TranslateTransform x:Name="slide" X="0"/></Grid.RenderTransform>

              <!-- soft recess shadow the cap casts on the lit plastic beneath it -->
              <Border x:Name="occlude" Width="23" Height="21" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0">
                <Border.Background>
                  <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.62" RadiusY="0.62">
                    <GradientStop Color="#73000000" Offset="0"/>
                    <GradientStop Color="#3C000000" Offset="0.65"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                  </RadialGradientBrush>
                </Border.Background>
              </Border>

              <!-- slider cap: thick beveled dark plastic -->
              <Border x:Name="thumb" Width="21" Height="19" CornerRadius="5">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#5A6356" Offset="0"/>
                    <GradientStop Color="#333C34" Offset="0.5"/>
                    <GradientStop Color="#242B25" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="1.5" Direction="270" Opacity="0.55"/></Border.Effect>
              </Border>

              <!-- light bleeding through the thick plastic cap, on the lens-facing edge -->
              <Border x:Name="capBleed" Width="21" Height="19" CornerRadius="5" Opacity="0">
                <Border.Background>
                  <RadialGradientBrush GradientOrigin="0.1,0.62" Center="0.1,0.62" RadiusX="0.95" RadiusY="1.0">
                    <GradientStop Color="{DynamicResource LampCapCore}" Offset="0"/>
                    <GradientStop Color="{DynamicResource LampCapMid}" Offset="0.35"/>
                    <GradientStop Color="{DynamicResource LampCapEdge}" Offset="0.9"/>
                  </RadialGradientBrush>
                </Border.Background>
              </Border>

              <!-- specular sheen along the cap top -->
              <Border x:Name="sheen" Width="15" Height="3" CornerRadius="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,3,0,0" Background="#26FFFFFF"/>
            </Grid>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <!-- cap snaps across with a slight mechanical overshoot -->
                    <DoubleAnimation Storyboard.TargetName="slide" Storyboard.TargetProperty="X" To="25" Duration="0:0:0.15">
                      <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- bulb warm-up: quick rise settling to full -->
                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- light takes a moment to bleed through the thick cap -->
                    <DoubleAnimation Storyboard.TargetName="capBleed" Storyboard.TargetProperty="Opacity" To="0.5" BeginTime="0:0:0.04" Duration="0:0:0.2"/>
                    <DoubleAnimation Storyboard.TargetName="occlude" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="slide" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15">
                      <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- bulb cool-down: fast initial drop, long dim tail (filament) -->
                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.34">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="capBleed" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="occlude" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
