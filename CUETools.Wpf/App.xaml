<Application x:Class="CUETools.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CUETools.Wpf.ViewModels"
             xmlns:views="clr-namespace:CUETools.Wpf.Views"
             xmlns:sel="clr-namespace:CUETools.Wpf.Selection"
             xmlns:conv="clr-namespace:CUETools.Wpf.Converters">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme/Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <!-- page placeholder (Phase 2); each page gets its real view in Phase 3 -->
      <DataTemplate x:Key="PageTemplate">
        <StackPanel Margin="28" VerticalAlignment="Top">
          <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="30" Foreground="{DynamicResource Ink}"/>
          <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource Muted}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
          <Border Margin="0,22,0,0" Padding="16,13" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" HorizontalAlignment="Left">
            <TextBlock Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="12" TextWrapping="Wrap" MaxWidth="520"
                       Text="Phase 2 shell - the app compiles, launches, and navigates over the .NET 8 engine. This screen gets its real UI in Phase 3, driven through the CUESheet facade."/>
          </Border>
        </StackPanel>
      </DataTemplate>

      <!-- real page views (extended per increment) + the selector that picks them -->
      <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
      <conv:ZeroToVisibilityConverter x:Key="ZeroToVis"/>
      <DataTemplate x:Key="RipTemplate"><views:RipView/></DataTemplate>
      <DataTemplate x:Key="VerifyTemplate"><views:VerifyView/></DataTemplate>
      <DataTemplate x:Key="ConvertTemplate"><views:ConvertView/></DataTemplate>
      <DataTemplate x:Key="QueueTemplate"><views:QueueView/></DataTemplate>
      <DataTemplate x:Key="DriveTemplate"><views:DriveView/></DataTemplate>
      <DataTemplate x:Key="ReportTemplate"><views:ReportView/></DataTemplate>
      <DataTemplate x:Key="SettingsTemplate"><views:SettingsView/></DataTemplate>
      <sel:PageTemplateSelector x:Key="PageSelector"
                                RipTemplate="{StaticResource RipTemplate}"
                                VerifyTemplate="{StaticResource VerifyTemplate}"
                                ConvertTemplate="{StaticResource ConvertTemplate}"
                                QueueTemplate="{StaticResource QueueTemplate}"
                                DriveTemplate="{StaticResource DriveTemplate}"
                                ReportTemplate="{StaticResource ReportTemplate}"
                                SettingsTemplate="{StaticResource SettingsTemplate}"
                                PlaceholderTemplate="{StaticResource PageTemplate}"/>

    </ResourceDictionary>
  </Application.Resources>
</Application>
