<Application x:Class="CUETools.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CUETools.Wpf.ViewModels"
             xmlns:views="clr-namespace:CUETools.Wpf.Views"
             xmlns:sel="clr-namespace:CUETools.Wpf.Selection"
             xmlns:conv="clr-namespace:CUETools.Wpf.Converters">
  <Application.Resources>
    <ResourceDictionary>

      <!-- palette: warm hi-fi-bench dark theme (light theme + physics come in a later pass) -->
      <SolidColorBrush x:Key="Ground"   Color="#0C0F0D"/>
      <SolidColorBrush x:Key="Bar"      Color="#0E1310"/>
      <SolidColorBrush x:Key="Face"     Color="#161C16"/>
      <SolidColorBrush x:Key="Panel"    Color="#141A16"/>
      <SolidColorBrush x:Key="Line"     Color="#28312A"/>
      <SolidColorBrush x:Key="Ink"      Color="#EDF1E9"/>
      <SolidColorBrush x:Key="InkDim"   Color="#B1BCAE"/>
      <SolidColorBrush x:Key="Muted"    Color="#7D887C"/>
      <SolidColorBrush x:Key="Teal"     Color="#34CFC0"/>
      <SolidColorBrush x:Key="Teal2"    Color="#46B8E0"/>
      <SolidColorBrush x:Key="Amber"    Color="#E9A63F"/>
      <SolidColorBrush x:Key="Good"     Color="#5CCB8B"/>
      <SolidColorBrush x:Key="Glass"    Color="#0E1311"/>
      <SolidColorBrush x:Key="GlassLine" Color="#243029"/>
      <SolidColorBrush x:Key="TealSoft" Color="#2434CFC0"/>

      <FontFamily x:Key="Serif">Sitka Text, Cambria, Georgia, serif</FontFamily>
      <FontFamily x:Key="Mono">Cascadia Mono, Consolas, monospace</FontFamily>

      <!-- left-nav item -->
      <Style x:Key="NavItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource InkDim}"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBoxItem">
              <Border x:Name="b" Background="Transparent" CornerRadius="9" Padding="{TemplateBinding Padding}">
                <ContentPresenter/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="b" Property="Background" Value="{StaticResource Panel}"/>
                  <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="b" Property="Background" Value="{StaticResource TealSoft}"/>
                  <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- physical lit switch: recessed dark track; a bulb under the translucent thumb shows a
           hotspot with real falloff to dark edges when on (matches the mockup's bulb physics) -->
      <Style x:Key="Switch" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Grid>
                <!-- recessed dark track (stays dark; only the thumb lights) -->
                <Border x:Name="track" CornerRadius="7" BorderThickness="1" BorderBrush="#151B16">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#070B08" Offset="0"/>
                      <GradientStop Color="#101710" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
                <!-- OFF: beveled dark-metal thumb -->
                <Border x:Name="thumb" Width="20" Height="18" CornerRadius="4" HorizontalAlignment="Left" Margin="2,0,0,0">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#565F52" Offset="0"/>
                      <GradientStop Color="#2A322B" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
                <!-- thin specular highlight along the thumb top (glass sheen) -->
                <Border x:Name="sheen" Width="16" Height="3" CornerRadius="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="4,2,0,0" Background="#22FFFFFF"/>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                  <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                  <Setter TargetName="sheen" Property="HorizontalAlignment" Value="Right"/>
                  <Setter TargetName="sheen" Property="Margin" Value="0,2,4,0"/>
                  <Setter TargetName="thumb" Property="Background">
                    <Setter.Value>
                      <!-- bulb under translucent plastic: bright core, falling off to dark edges -->
                      <RadialGradientBrush GradientOrigin="0.5,0.6" Center="0.5,0.6" RadiusX="0.58" RadiusY="0.82">
                        <GradientStop Color="#F4FFFD" Offset="0"/>
                        <GradientStop Color="#8FE9DE" Offset="0.2"/>
                        <GradientStop Color="#34CFC0" Offset="0.48"/>
                        <GradientStop Color="#136B60" Offset="0.78"/>
                        <GradientStop Color="#092824" Offset="1"/>
                      </RadialGradientBrush>
                    </Setter.Value>
                  </Setter>
                  <Setter TargetName="thumb" Property="Effect">
                    <Setter.Value><DropShadowEffect Color="#34CFC0" BlurRadius="13" ShadowDepth="0" Opacity="0.9"/></Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- page placeholder (Phase 2); each page gets its real view in Phase 3 -->
      <DataTemplate x:Key="PageTemplate">
        <StackPanel Margin="28" VerticalAlignment="Top">
          <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="30" Foreground="{StaticResource Ink}"/>
          <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
          <Border Margin="0,22,0,0" Padding="16,13" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" HorizontalAlignment="Left">
            <TextBlock Foreground="{StaticResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="12" TextWrapping="Wrap" MaxWidth="520"
                       Text="Phase 2 shell - the app compiles, launches, and navigates over the .NET 8 engine. This screen gets its real UI in Phase 3, driven through the CUESheet facade."/>
          </Border>
        </StackPanel>
      </DataTemplate>

      <!-- real page views (extended per increment) + the selector that picks them -->
      <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
      <DataTemplate x:Key="RipTemplate"><views:RipView/></DataTemplate>
      <DataTemplate x:Key="SettingsTemplate"><views:SettingsView/></DataTemplate>
      <sel:PageTemplateSelector x:Key="PageSelector"
                                RipTemplate="{StaticResource RipTemplate}"
                                SettingsTemplate="{StaticResource SettingsTemplate}"
                                PlaceholderTemplate="{StaticResource PageTemplate}"/>

    </ResourceDictionary>
  </Application.Resources>
</Application>
