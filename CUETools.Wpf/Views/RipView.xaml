<UserControl x:Class="CUETools.Wpf.Views.RipView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{StaticResource Ground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- drive / disc bar -->
    <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="16,10">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="Drive" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <ComboBox DockPanel.Dock="Left" Width="80" VerticalAlignment="Center"
                  ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"/>
        <TextBlock DockPanel.Dock="Left" Margin="16,0,0,0" VerticalAlignment="Center"
                   Text="{Binding DiscInfoText}" Foreground="{StaticResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11.5"/>
        <Button DockPanel.Dock="Right" Content="Read disc" Command="{Binding ReadDiscCommand}" Padding="12,6" VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- disc present: metadata + tracks + action bar -->
    <Grid Grid.Row="1" Visibility="{Binding IsDiscPresent, Converter={StaticResource BoolVis}}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="18,16,18,8">
        <TextBlock Text="{Binding AlbumTitle}" FontFamily="{StaticResource Serif}" FontSize="24" Foreground="{StaticResource Ink}"/>
        <TextBlock Text="{Binding AlbumArtist}" FontFamily="{StaticResource Serif}" FontStyle="Italic" FontSize="14" Foreground="{StaticResource InkDim}" Margin="0,2,0,0"/>
      </StackPanel>

      <ListView Grid.Row="1" Margin="18,4,18,4" ItemsSource="{Binding Tracks}"
                Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Foreground="{StaticResource Ink}">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="#" Width="44" DisplayMemberBinding="{Binding Number}"/>
            <GridViewColumn Header="Title" Width="420" DisplayMemberBinding="{Binding Title}"/>
            <GridViewColumn Header="Length" Width="90" DisplayMemberBinding="{Binding LengthText}"/>
          </GridView>
        </ListView.View>
      </ListView>

      <Border Grid.Row="2" Background="{StaticResource Face}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,12">
        <DockPanel LastChildFill="False">
          <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
          <Button DockPanel.Dock="Right" Content="Rip" Padding="20,9" IsEnabled="False"/>
          <ComboBox DockPanel.Dock="Right" Width="130" Margin="0,0,10,0" SelectedIndex="0" VerticalAlignment="Center">
            <ComboBoxItem>FLAC -8</ComboBoxItem>
            <ComboBoxItem>Opus 192</ComboBoxItem>
            <ComboBoxItem>WavPack</ComboBoxItem>
            <ComboBoxItem>ALAC</ComboBoxItem>
          </ComboBox>
        </DockPanel>
      </Border>
    </Grid>

    <!-- no disc: status + recently ripped -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding IsDiscPresent, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
      <StackPanel Margin="24">
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="18,15" Margin="0,4,0,18">
          <StackPanel>
            <TextBlock Text="{Binding AlbumTitle}" FontFamily="{StaticResource Serif}" FontSize="20" Foreground="{StaticResource Ink}"/>
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <TextBlock Text="RECENTLY RIPPED - LAST 10" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Muted}" Margin="2,0,0,9"/>
        <ItemsControl ItemsSource="{Binding Recent}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="9" Padding="13,10" Margin="0,0,0,8">
                <DockPanel LastChildFill="False">
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="14" Foreground="{StaticResource Ink}"/>
                    <TextBlock Text="{Binding Artist}" FontFamily="{StaticResource Serif}" FontStyle="Italic" FontSize="11.5" Foreground="{StaticResource Muted}"/>
                  </StackPanel>
                  <TextBlock DockPanel.Dock="Right" Text="{Binding Result}" Foreground="{StaticResource Teal}" FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"/>
                  <TextBlock DockPanel.Dock="Right" Text="{Binding When}" Foreground="{StaticResource Muted}" FontFamily="{StaticResource Mono}" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0"/>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
