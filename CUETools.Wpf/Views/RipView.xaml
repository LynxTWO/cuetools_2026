<UserControl x:Class="CUETools.Wpf.Views.RipView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:CUETools.Wpf.Controls">
  <Grid Background="{DynamicResource Ground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- drive / disc bar -->
    <Border Grid.Row="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,10">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="Drive" Foreground="{DynamicResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <ComboBox DockPanel.Dock="Left" Width="80" VerticalAlignment="Center"
                  ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"/>
        <!-- real drive model, read from INQUIRY (no disc needed) -->
        <TextBlock DockPanel.Dock="Left" Margin="12,0,0,0" VerticalAlignment="Center"
                   Text="{Binding DriveModel}" Foreground="{DynamicResource Ink}" FontSize="12" FontWeight="SemiBold"/>
        <TextBlock DockPanel.Dock="Left" Margin="16,0,0,0" VerticalAlignment="Center"
                   Text="{Binding DiscInfoText}" Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11.5"/>
        <Button DockPanel.Dock="Right" Content="{Binding EjectButtonText}" Command="{Binding EjectCommand}" Padding="12,6" Margin="8,0,0,0" VerticalAlignment="Center"
                ToolTip="{Binding EjectButtonTip}"/>
        <Button DockPanel.Dock="Right" Content="Read disc" Command="{Binding ReadDiscCommand}" Padding="12,6" VerticalAlignment="Center"/>
        <!-- release picker: ranked best-first by source + completeness; pick one to relabel -->
        <ComboBox DockPanel.Dock="Right" Width="320" Margin="10,0,10,0" VerticalAlignment="Center"
                  ItemsSource="{Binding Releases}" SelectedItem="{Binding SelectedRelease, Mode=TwoWay}"
                  Visibility="{Binding HasReleases, Converter={StaticResource BoolVis}}"
                  ToolTip="Metadata release used for this rip. Ranked best-first by source quality and how complete the info is. Pick one to relabel the album and tracks.">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <DockPanel MinWidth="264" ToolTip="{Binding Why}">
                <Border DockPanel.Dock="Right" Background="{StaticResource Teal}" CornerRadius="3" Padding="5,0" Margin="6,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsBest, Converter={StaticResource BoolVis}}">
                  <TextBlock Text="BEST" FontSize="8" FontWeight="Bold" Foreground="#04110F"/>
                </Border>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Source}" Foreground="{DynamicResource Muted}" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Text="{Binding Header}" Foreground="{DynamicResource Ink}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
              </DockPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </DockPanel>
    </Border>

    <!-- disc present: metadata + tracks + action bar -->
    <Grid Grid.Row="1" Visibility="{Binding IsDiscPresent, Converter={StaticResource BoolVis}}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="252"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="234"/>
      </Grid.ColumnDefinitions>

      <!-- right: AccurateRip / CTDB / options -->
      <Border Grid.Column="2" Grid.RowSpan="3" BorderBrush="{DynamicResource Line}" BorderThickness="1,0,0,0" Padding="14,16">
        <StackPanel>
          <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="13" Margin="0,0,0,11">
            <StackPanel>
              <TextBlock Text="ACCURATERIP" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="0,0,0,7"/>
              <TextBlock Text="{Binding ArText}" FontFamily="{StaticResource Mono}" FontSize="15" Foreground="{StaticResource Good}"/>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="13" Margin="0,0,0,11">
            <StackPanel>
              <TextBlock Text="CTDB" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="0,0,0,7"/>
              <TextBlock Text="{Binding CtdbText}" FontFamily="{StaticResource Mono}" FontSize="13" Foreground="{StaticResource Good}"/>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="13">
            <StackPanel>
              <TextBlock Text="OPTIONS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="0,0,0,8"/>
              <DockPanel Margin="0,3,0,0"><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CreateCue}"/><TextBlock Text="Create .cue sheet" Foreground="{DynamicResource InkDim}" FontSize="12.5" VerticalAlignment="Center"/></DockPanel>
              <DockPanel Margin="0,8,0,0"><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding WriteLog}"/><TextBlock Text="Write rip log" Foreground="{DynamicResource InkDim}" FontSize="12.5" VerticalAlignment="Center"/></DockPanel>
              <DockPanel Margin="0,8,0,0"><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding EmbedArt}"/><TextBlock Text="Embed cover art" Foreground="{DynamicResource InkDim}" FontSize="12.5" VerticalAlignment="Center"/></DockPanel>
              <!-- preview of the exact cover to be embedded: the largest Apple master (UPC-exact when
                   the disc carries a barcode), resized with the RIOT-matched filter; database cover if none -->
              <StackPanel Margin="0,10,0,0" Visibility="{Binding EmbedArt, Converter={StaticResource BoolVis}}">
                <Border Width="132" Height="132" HorizontalAlignment="Left" CornerRadius="6" ClipToBounds="True"
                        Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1"
                        Visibility="{Binding HasArtPreview, Converter={StaticResource BoolVis}}">
                  <Image Source="{Binding ArtPreview}" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding ArtInfo}" Foreground="{DynamicResource Muted}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                           TextWrapping="Wrap" Margin="0,5,0,0"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- left: live disc read-map -->
      <Border Grid.Column="0" Grid.RowSpan="3" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,18">
        <StackPanel VerticalAlignment="Top">
          <!-- 3D disc on GPU-accelerated hardware; the 2D read-map is the software-rendering fallback -->
          <ctl:DiscModel3D Width="216" Height="216" HorizontalAlignment="Center"
                           Progress="{Binding RipProgress, Mode=OneWay}" Active="{Binding IsRipping, Mode=OneWay}"
                           RereadActive="{Binding RereadActive, Mode=OneWay}" RereadFrac="{Binding RereadFrac, Mode=OneWay}"
                           Unreadable="{Binding Unreadable, Mode=OneWay}"
                           Visibility="{Binding Supports3DDisc, Converter={StaticResource BoolVis}}"/>
          <ctl:DiscReadMap Width="216" Height="216" HorizontalAlignment="Center" Progress="{Binding RipProgress, Mode=OneWay}"
                           Visibility="{Binding Supports3DDisc, Converter={StaticResource BoolVis}, ConverterParameter=invert}"/>
          <TextBlock Text="reading inside-out" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Muted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
          <Border Margin="0,16,0,0" Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="10" Padding="11,9">
            <StackPanel>
              <DockPanel LastChildFill="False" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Left" Text="READ LEVEL" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Amber}"/>
                <TextBlock DockPanel.Dock="Right" Text="dB -20 . 0 . +3" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Muted}"/>
              </DockPanel>
              <ctl:VuMeter Height="74" Active="{Binding IsRipping, Mode=OneWay}"
                           LevelL="{Binding LevelL, Mode=OneWay}" LevelR="{Binding LevelR, Mode=OneWay}"/>
            </StackPanel>
          </Border>
          <Border Margin="0,11,0,0" Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="10" Padding="11,9">
            <StackPanel>
              <DockPanel LastChildFill="False" Margin="0,0,0,6">
                <TextBlock DockPanel.Dock="Left" Text="READ SPEED" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Teal}"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding SpeedText}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource InkDim}"/>
              </DockPanel>
              <ctl:SpeedGraph Height="64" Level="{Binding SpeedLevel, Mode=OneWay}" Active="{Binding IsRipping, Mode=OneWay}"/>
            </StackPanel>
          </Border>
          <!-- appears only when the drive is genuinely re-reading a stuck sector (scratch / pin-hole);
               every number is the drive's real retry count, not a canned animation -->
          <Border Margin="0,11,0,0" Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="10" Padding="11,9"
                  Visibility="{Binding RereadVisible, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <DockPanel LastChildFill="False" Margin="0,0,0,6">
                <TextBlock DockPanel.Dock="Left" Text="RE-READING" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Amber}"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding RereadText}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Muted}"/>
              </DockPanel>
              <ctl:RereadScope Height="56" Active="{Binding RereadActive, Mode=OneWay}"
                               Count="{Binding RereadCount, Mode=OneWay}" Max="{Binding RereadMax, Mode=OneWay}"
                               Errors="{Binding RereadErrors, Mode=OneWay}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="0" Grid.Column="1" Margin="18,16,18,8">
        <TextBlock Text="{Binding AlbumTitle}" FontFamily="{StaticResource Serif}" FontSize="24" Foreground="{DynamicResource Ink}"/>
        <TextBlock Text="{Binding AlbumArtist}" FontFamily="{StaticResource Serif}" FontStyle="Italic" FontSize="14" Foreground="{DynamicResource InkDim}" Margin="0,2,0,0"/>
        <!-- why this release was chosen (all matches fit the disc; ranked by source + completeness) -->
        <TextBlock Text="{Binding SelectedRelease.Why}" Foreground="{DynamicResource Muted}" FontFamily="{StaticResource Mono}" FontSize="10.5" Margin="0,5,0,0" TextWrapping="Wrap"
                   Visibility="{Binding HasReleases, Converter={StaticResource BoolVis}}"/>
      </StackPanel>

      <ListView Grid.Row="1" Grid.Column="1" Margin="18,4,18,4" ItemsSource="{Binding Tracks}"
                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" Foreground="{DynamicResource Ink}">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="#" Width="32" DisplayMemberBinding="{Binding Number}"/>
            <GridViewColumn Header="Title" Width="238">
              <GridViewColumn.CellTemplate>
                <DataTemplate>
                  <Grid>
                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <!-- live per-track read progress (only while ripping) -->
                    <ProgressBar Height="2" VerticalAlignment="Bottom" Margin="0,0,6,-3" Minimum="0" Maximum="1" Value="{Binding Progress}"
                                 Background="Transparent" Foreground="{DynamicResource Teal}" BorderThickness="0"
                                 Visibility="{Binding DataContext.IsRipping, RelativeSource={RelativeSource AncestorType=ListView}, Converter={StaticResource BoolVis}}"/>
                  </Grid>
                </DataTemplate>
              </GridViewColumn.CellTemplate>
            </GridViewColumn>
            <GridViewColumn Header="Len" Width="52" DisplayMemberBinding="{Binding LengthText}"/>
            <GridViewColumn Header="AR" Width="48" DisplayMemberBinding="{Binding ArResult}"/>
            <GridViewColumn Header="CTDB" Width="52" DisplayMemberBinding="{Binding CtdbResult}"/>
          </GridView>
        </ListView.View>
      </ListView>

      <!-- during a rip: an educational view of what the codec is doing to the audio -->
      <Border Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Margin="18,0,18,10"
              Background="{DynamicResource Face}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,11"
              Visibility="{Binding IsRipping, Converter={StaticResource BoolVis}}">
        <ctl:CodecScope Height="150" Codec="{Binding SelectedFormat, Mode=OneWay}" Active="{Binding IsRipping, Mode=OneWay}"
                        Samples="{Binding SampleWindow, Mode=OneWay}"/>
      </Border>

      <!-- rip complete: a clear finished state with the result + where the files went -->
      <Border Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="18,10,18,0"
              Background="{DynamicResource Glass}" BorderBrush="{StaticResource Good}" BorderThickness="1" CornerRadius="11" Padding="16,13"
              Visibility="{Binding RipDone, Converter={StaticResource BoolVis}}">
        <DockPanel LastChildFill="True">
          <Ellipse DockPanel.Dock="Left" Width="14" Height="14" Fill="{StaticResource Good}" VerticalAlignment="Top" Margin="0,2,12,0">
            <Ellipse.Effect><DropShadowEffect Color="#5CCB8B" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
          </Ellipse>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
            <Button Content="Open folder" Command="{Binding OpenFolderCommand}" Style="{StaticResource Accent}" Padding="12,6"/>
            <Button Content="Dismiss" Command="{Binding DismissDoneCommand}" Padding="10,6" Margin="8,0,0,0"/>
          </StackPanel>
          <StackPanel>
            <TextBlock Text="Rip complete" Foreground="{DynamicResource Ink}" FontFamily="{StaticResource Serif}" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding RipSummary}" Foreground="{DynamicResource InkDim}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding LastOutputDir}" Foreground="{DynamicResource Muted}" FontFamily="{StaticResource Mono}" FontSize="10.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource Face}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="16,12">
        <DockPanel LastChildFill="False">
          <!-- Stop replaces the primary action while a rip/verify runs; Rip/Verify grey out. -->
          <Button DockPanel.Dock="Right" Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource Accent}" Padding="18,9"
                  Visibility="{Binding IsRipping, Converter={StaticResource BoolVis}}"
                  ToolTip="Stop the rip or verify. It finishes the current block, then stops cleanly."/>
          <Button DockPanel.Dock="Right" Content="Verify" Command="{Binding VerifyCommand}" Padding="18,9" Margin="0,0,10,0"
                  Visibility="{Binding IsRipping, Converter={StaticResource BoolVis}, ConverterParameter=invert}"/>
          <Button DockPanel.Dock="Right" Content="Rip" Command="{Binding RipCommand}" Style="{StaticResource Accent}" Padding="18,9" Margin="0,0,10,0"
                  Visibility="{Binding IsRipping, Converter={StaticResource BoolVis}, ConverterParameter=invert}"/>
          <Button DockPanel.Dock="Right" Content="tune" FontFamily="{StaticResource Mono}" FontSize="11" Padding="9,6" Margin="0,0,10,0" VerticalAlignment="Center"
                  Click="EncoderSettings_Click"
                  ToolTip="Encoder settings for the selected format: compression / quality mode and every advanced option the codec exposes, each with an explanation."/>
          <ComboBox DockPanel.Dock="Right" Width="120" Margin="0,0,6,0" VerticalAlignment="Center"
                    ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat, Mode=TwoWay}"
                    ToolTip="Output format (only codecs with a working encoder on this machine are listed - see Settings for more encoders)."/>
          <ComboBox DockPanel.Dock="Right" Width="104" Margin="0,0,10,0" SelectedIndex="{Binding CorrectionQuality, Mode=TwoWay}" VerticalAlignment="Center"
                    ToolTip="Burst: fast, single pass. Secure: read twice + compare. Paranoid: deepest re-reads.">
            <ComboBoxItem>Burst</ComboBoxItem>
            <ComboBoxItem>Secure</ComboBoxItem>
            <ComboBoxItem>Paranoid</ComboBoxItem>
          </ComboBox>
          <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Muted}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="440"/>
            <ProgressBar Height="4" Width="240" Minimum="0" Maximum="1" Value="{Binding RipProgress, Mode=OneWay}" Margin="0,5,0,0" HorizontalAlignment="Left"
                         Background="{DynamicResource Glass}" Foreground="{StaticResource Teal}" BorderThickness="0"/>
            <!-- where the ripped album folder is created -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock Text="saves to" Foreground="{DynamicResource Muted}" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <TextBlock Text="{Binding OutputBaseDir}" Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="330"/>
              <Button Content="Change..." Command="{Binding BrowseOutputCommand}" Padding="8,2" Margin="8,0,0,0" FontSize="10.5"
                      ToolTip="Choose the base folder. Each album gets its own 'Artist - Album' subfolder here."/>
            </StackPanel>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>

    <!-- no disc: status + recently ripped -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding IsDiscPresent, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
      <StackPanel Margin="24">
        <!-- the drive tray: slides out on Eject, pulls in on Close, then the disc reads itself -->
        <ctl:DiscTray Width="264" Height="150" HorizontalAlignment="Center" Margin="0,2,0,6"
                      Open="{Binding IsTrayOpen, Mode=OneWay}"/>
        <TextBlock Text="Drop in a disc and press Close (or the drive's own button) - it reads automatically."
                   Foreground="{DynamicResource Muted}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                   HorizontalAlignment="Center" Margin="0,0,0,16" TextWrapping="Wrap" TextAlignment="Center"
                   Visibility="{Binding IsTrayOpen, Converter={StaticResource BoolVis}}"/>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="10" Padding="18,15" Margin="0,4,0,18">
          <StackPanel>
            <TextBlock Text="{Binding AlbumTitle}" FontFamily="{StaticResource Serif}" FontSize="20" Foreground="{DynamicResource Ink}"/>
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Muted}" FontSize="12.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- empty state: no history yet (honest - shown until real rips accumulate) -->
        <TextBlock Text="No rips yet. Insert a disc and rip or verify it - the last ten show up here so you can keep a stack of discs straight."
                   Foreground="{DynamicResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="2,0,0,0"
                   Visibility="{Binding Recent.Count, Converter={StaticResource ZeroToVis}}"/>

        <!-- history list (header + rows) hidden until there is at least one entry -->
        <StackPanel>
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Style.Triggers>
                <DataTrigger Binding="{Binding Recent.Count}" Value="0">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text="RECENTLY RIPPED - LAST 10" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="2,0,0,9"/>
          <ItemsControl ItemsSource="{Binding Recent}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="13,10" Margin="0,0,0,8">
                  <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                      <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="14" Foreground="{DynamicResource Ink}"/>
                      <TextBlock Text="{Binding Artist}" FontFamily="{StaticResource Serif}" FontStyle="Italic" FontSize="11.5" Foreground="{DynamicResource Muted}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding Result}" Foreground="{StaticResource Teal}" FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding When}" Foreground="{DynamicResource Muted}" FontFamily="{StaticResource Mono}" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0"/>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
