<UserControl x:Class="CUETools.Wpf.Views.DriveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Background="{DynamicResource Ground}" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" MaxWidth="820" HorizontalAlignment="Left">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="26" Foreground="{DynamicResource Ink}"/>
          <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource Muted}" FontSize="12.5" Margin="0,2,0,0" TextWrapping="Wrap" MaxWidth="620"/>
        </StackPanel>
        <Button DockPanel.Dock="Right" Content="Detect" Command="{Binding DetectCommand}" Style="{StaticResource Accent}" Padding="16,8" VerticalAlignment="Top"
                ToolTip="Re-read the drive over SCSI (identity, capabilities, speeds, offset)."/>
      </DockPanel>

      <!-- identity + read offset -->
      <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="12" Padding="18,16" Margin="0,16,0,14"
              Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{DynamicResource Muted}">
              <Run Text="{Binding DriveLetter, Mode=OneWay}"/><Run Text="  -  "/><Run Text="{Binding Details.CurrentProfile, Mode=OneWay}"/><Run Text=" loaded"/>
            </TextBlock>
            <TextBlock Text="{Binding Details.Model}" FontFamily="{StaticResource Serif}" FontSize="22" Foreground="{DynamicResource Ink}" Margin="0,2,0,0"/>
            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource InkDim}" Margin="0,4,0,0">
              <Run Text="firmware "/><Run Text="{Binding Details.Firmware, Mode=OneWay}"/><Run Text="   rev "/><Run Text="{Binding Details.ProductRevision, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Muted}" Margin="0,2,0,0">
              <Run Text="AccurateRip name  "/><Run Text="{Binding Details.ARName, Mode=OneWay}"/>
            </TextBlock>
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="20,0,0,0">
            <TextBlock Text="READ OFFSET" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding Details.OffsetText}" FontFamily="{StaticResource Mono}" FontSize="24" Foreground="{StaticResource Teal}" HorizontalAlignment="Right"/>
            <TextBlock Text="AccurateRip, samples" FontSize="9" Foreground="{DynamicResource Muted}" HorizontalAlignment="Right"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- real capability lamps (read from GET CONFIGURATION - not hardcoded) -->
      <UniformGrid Columns="2" Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}">
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Good}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel><TextBlock Text="Reads" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/><TextBlock Text="{Binding Details.ReadsSummary}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{Binding Details.CanWriteCD, Converter={StaticResource BoolBrush}, ConverterParameter=Good;Muted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel><TextBlock Text="Writes" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/><TextBlock Text="{Binding Details.WritesSummary}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{Binding Details.C2ErrorPointers, Converter={StaticResource BoolBrush}, ConverterParameter=Good;Amber}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel><TextBlock Text="C2 error pointers" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/><TextBlock Text="reports read errors per sector" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{Binding Details.CdText, Converter={StaticResource BoolBrush}, ConverterParameter=Good;Muted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel><TextBlock Text="CD-Text" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/><TextBlock Text="reads disc-embedded titles" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,0">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Teal}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
              <TextBlock Text="Max read speed" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
              <TextBlock Text="{Binding Details.ReadSpeedText}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/>
            </StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,0">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Teal}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
              <TextBlock Text="Max transfer" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
              <TextBlock Text="{Binding Details.MaxTransferText}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}"/>
            </StackPanel>
          </DockPanel>
        </Border>
      </UniformGrid>

      <!-- supported media (profiles) -->
      <TextBlock Text="SUPPORTED MEDIA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="2,18,0,8"
                 Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}"/>
      <ItemsControl ItemsSource="{Binding Details.SupportedProfiles}" Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}">
        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="6" Padding="9,4" Margin="0,0,7,7">
              <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource InkDim}"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- full GET CONFIGURATION feature list; lit dot = currently active -->
      <TextBlock Text="DRIVE FEATURES  (GET CONFIGURATION)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" Margin="2,16,0,8"
                 Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}"/>
      <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="10" Padding="6"
              Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}">
        <ItemsControl ItemsSource="{Binding Details.Features}">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="9,5" Margin="3" CornerRadius="6" Background="{DynamicResource Glass}"
                      ToolTip="{Binding CodeHex}">
                <DockPanel>
                  <Ellipse DockPanel.Dock="Left" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,7,0"
                           Fill="{Binding Current, Converter={StaticResource BoolBrush}, ConverterParameter=Good;Line}"/>
                  <TextBlock Text="{Binding Name}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource InkDim}"/>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Muted}" FontSize="12" Margin="2,16,0,0" TextWrapping="Wrap"/>
      <TextBlock Text="All values are read live from the drive over SCSI (INQUIRY, GET CONFIGURATION, GET PERFORMANCE). A lit dot means the feature is currently active; the read offset comes from the AccurateRip drive database."
                 FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}" Margin="2,8,0,0" TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
