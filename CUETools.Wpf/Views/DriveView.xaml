<UserControl x:Class="CUETools.Wpf.Views.DriveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Background="{StaticResource Ground}" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" MaxWidth="760" HorizontalAlignment="Left">
      <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="26" Foreground="{StaticResource Ink}"/>
      <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,2,0,18" TextWrapping="Wrap"/>

      <!-- drive + offset + detect -->
      <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12" Padding="18,16" Margin="0,0,0,16">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="{Binding DriveLetter}" FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Muted}"/>
            <TextBlock Text="{Binding DriveModel}" FontFamily="{StaticResource Serif}" FontSize="20" Foreground="{StaticResource Ink}" Margin="0,2,0,0"/>
          </StackPanel>
          <Button DockPanel.Dock="Right" Content="Detect" Command="{Binding DetectCommand}" Style="{StaticResource Accent}" Padding="16,8" VerticalAlignment="Center"/>
          <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,20,0">
            <TextBlock Text="READ OFFSET" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Muted}" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding OffsetText}" FontFamily="{StaticResource Mono}" FontSize="23" Foreground="{StaticResource Teal}" HorizontalAlignment="Right"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- capability lamps -->
      <UniformGrid Columns="2">
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Good}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#5CCB8B" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="C2 error pointers" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="supported" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Good}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#5CCB8B" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="Accurate Stream" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="yes" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Teal}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#34CFC0" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="Read command" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="auto-detect (D8h / BEh)" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,10">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Amber}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#E9A63F" BlurRadius="10" ShadowDepth="0" Opacity="0.85"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="Cache defeat" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="planned (FUA / flush)" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,10,0">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Amber}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#E9A63F" BlurRadius="10" ShadowDepth="0" Opacity="0.85"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="Overread lead-in" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="planned" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="11" Padding="14,13" Margin="0,0,0,0">
          <DockPanel>
            <Ellipse DockPanel.Dock="Left" Width="15" Height="15" Fill="{StaticResource Amber}" VerticalAlignment="Center" Margin="0,0,12,0"><Ellipse.Effect><DropShadowEffect Color="#E9A63F" BlurRadius="10" ShadowDepth="0" Opacity="0.85"/></Ellipse.Effect></Ellipse>
            <StackPanel><TextBlock Text="Overread lead-out" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/><TextBlock Text="planned" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}"/></StackPanel>
          </DockPanel>
        </Border>
      </UniformGrid>

      <TextBlock Text="{Binding Status}" Foreground="{StaticResource Muted}" FontSize="12" Margin="2,16,0,0" TextWrapping="Wrap"/>
      <TextBlock Text="Model + offset are read from the drive. Cache defeat and lead-in/lead-out overread are planned (design spec) - shown honestly, not faked." FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Muted}" Margin="2,10,0,0" TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
