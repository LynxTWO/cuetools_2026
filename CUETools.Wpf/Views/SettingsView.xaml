<UserControl x:Class="CUETools.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <Style x:Key="Sec" TargetType="TextBlock">
      <Setter Property="FontSize" Value="9.5"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
      <Setter Property="Margin" Value="2,20,0,6"/>
    </Style>
    <Style x:Key="RowLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="Row" TargetType="Border">
      <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="2,9"/>
    </Style>
    <Style x:Key="Box" TargetType="TextBox">
      <Setter Property="Background" Value="{DynamicResource Glass}"/>
      <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource GlassLine}"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </UserControl.Resources>

  <ScrollViewer Background="{DynamicResource Ground}" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" MaxWidth="720" HorizontalAlignment="Left">
      <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="26" Foreground="{DynamicResource Ink}"/>
      <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource Muted}" FontSize="12.5" Margin="0,2,0,4" TextWrapping="Wrap"/>

      <TextBlock Style="{StaticResource Sec}" Text="RIPPING"/>
      <Border Style="{StaticResource Row}" ToolTip="Keep the computer awake (no sleep, no display timeout) while a rip or verify runs, so a long secure rip is not cut short by the machine sleeping. On by default."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding PreventSleepDuringRip}"/><TextBlock Style="{StaticResource RowLabel}" Text="Keep computer awake during a rip"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Lock the drive tray while a rip or verify runs so the disc cannot be ejected mid-read - by its own button or by software. This prevents an accidental eject from failing the read. Off by default."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding LockTrayDuringRip}"/><TextBlock Style="{StaticResource RowLabel}" Text="Lock drive tray during a rip"/></DockPanel></Border>

      <TextBlock Style="{StaticResource Sec}" Text="GENERAL"/>
      <Border Style="{StaticResource Row}" ToolTip="Keep only one CUETools window open; launching again focuses the existing one instead of opening a second."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding OneInstance}"/><TextBlock Style="{StaticResource RowLabel}" Text="Single instance"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Check online for a newer CUETools version when the app starts."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CheckForUpdates}"/><TextBlock Style="{StaticResource RowLabel}" Text="Check for updates"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Decode audio on a separate thread from encoding. Can be faster on multi-core CPUs."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding SeparateDecodingThread}"/><TextBlock Style="{StaticResource RowLabel}" Text="Separate decoding thread"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Open the drive tray automatically when a rip finishes."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding EjectAfterRip}"/><TextBlock Style="{StaticResource RowLabel}" Text="Eject after rip"/></DockPanel></Border>

      <TextBlock Style="{StaticResource Sec}" Text="ACCURATERIP &amp; CTDB"/>
      <Border Style="{StaticResource Row}" ToolTip="Refuse to keep output that could not be verified against AccurateRip. Safest, but discs not in the database will not be written."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding NoUnverifiedOutput}"/><TextBlock Style="{StaticResource RowLabel}" Text="No unverified output"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Shift the samples by the drive's write offset so the output lines up exactly with AccurateRip's reference."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding FixOffset}"/><TextBlock Style="{StaticResource RowLabel}" Text="Apply write-offset correction"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Embed the AccurateRip confidence and CRCs into the encoded files' tags (proof of an accurate rip)."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding WriteArTagsOnEncode}"/><TextBlock Style="{StaticResource RowLabel}" Text="Write AccurateRip tags on encode"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Write an AccurateRip verification log when converting existing files (not ripping)."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding WriteArLogOnConvert}"/><TextBlock Style="{StaticResource RowLabel}" Text="Write AccurateRip log on convert"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Send your verified rip's fingerprint and parity to the CUETools Database so others can verify (and repair) the same disc."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CtdbSubmit}"/><TextBlock Style="{StaticResource RowLabel}" Text="Submit to CTDB"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Prompt before each CTDB submission instead of submitting automatically."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CtdbAsk}"/><TextBlock Style="{StaticResource RowLabel}" Text="Ask before submitting"/></DockPanel></Border>

      <TextBlock Style="{StaticResource Sec}" Text="FILE NAMING &amp; OUTPUT"/>
      <Border Style="{StaticResource Row}" ToolTip="How ripped track files are named. Use fields like %tracknumber%, %title%, %artist%, %album%."><DockPanel><TextBox DockPanel.Dock="Right" Width="260" Style="{StaticResource Box}" Text="{Binding TrackFilenameFormat, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Style="{StaticResource RowLabel}" Text="Track filename template"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Also write a .cue sheet when ripping to individual track files (records the disc layout and gaps)."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CreateCueInTracksMode}"/><TextBlock Style="{StaticResource RowLabel}" Text="Create .cue sheet in tracks mode"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Write an .m3u playlist listing the tracks in order alongside the files."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CreateM3U}"/><TextBlock Style="{StaticResource RowLabel}" Text="Create .m3u playlist"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Write a detailed rip log in the Exact Audio Copy (EAC) format."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CreateEacLog}"/><TextBlock Style="{StaticResource RowLabel}" Text="EAC-style rip log"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Prefix the .cue file with a UTF-8 byte-order mark so players reliably detect the text encoding."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding WriteUtf8Bom}"/><TextBlock Style="{StaticResource RowLabel}" Text="UTF-8 byte-order mark in .cue"/></DockPanel></Border>

      <TextBlock Style="{StaticResource Sec}" Text="GAPS &amp; HTOA"/>
      <Border Style="{StaticResource Row}" ToolTip="Find the exact pre-gaps between tracks by reading the subchannel, so gaps are placed correctly."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding DetectGaps}"/><TextBlock Style="{StaticResource RowLabel}" Text="Detect gaps"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Keep the hidden audio before track 1. Some albums hide a track in the pre-gap of track 1."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding PreserveHtoa}"/><TextBlock Style="{StaticResource RowLabel}" Text="Preserve HTOA (hidden track one audio)"/></DockPanel></Border>
      <Border Style="{StaticResource Row}" ToolTip="Only keep a hidden pre-track if it is longer than about 5 seconds, so tiny silent gaps are ignored."><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding UseHtoaThreshold}"/><TextBlock Style="{StaticResource RowLabel}" Text="HTOA length threshold (5 s)"/></DockPanel></Border>

      <!-- metadata / presentation settings: amber bulbs (color-coded category) -->
      <StackPanel>
        <StackPanel.Resources>
          <Color x:Key="LampCore">#FFF6E9</Color><Color x:Key="LampLight">#F0C784</Color><Color x:Key="LampBase">#C8871F</Color>
          <Color x:Key="LampDark">#7A5416</Color><Color x:Key="LampEdge">#241804</Color><Color x:Key="LampHalo">#E9A63F</Color>
          <Color x:Key="LampCapCore">#B8FFF8EE</Color><Color x:Key="LampCapMid">#5AE0A94A</Color><Color x:Key="LampCapEdge">#00E9A63F</Color>
        </StackPanel.Resources>
        <TextBlock Style="{StaticResource Sec}" Text="TAGGING"/>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding BasicTagsFromCue}"/><TextBlock Style="{StaticResource RowLabel}" Text="Basic tags from CUE metadata"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CopyBasicTags}"/><TextBlock Style="{StaticResource RowLabel}" Text="Copy basic tags from source"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding CopyUnknownTags}"/><TextBlock Style="{StaticResource RowLabel}" Text="Copy unknown / extra tags"/></DockPanel></Border>

        <TextBlock Style="{StaticResource Sec}" Text="ALBUM ART"/>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding EmbedAlbumArt}"/><TextBlock Style="{StaticResource RowLabel}" Text="Embed album art"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding ExtractAlbumArt}"/><TextBlock Style="{StaticResource RowLabel}" Text="Extract album art to a folder image"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><TextBox DockPanel.Dock="Right" Width="90" Style="{StaticResource Box}" Text="{Binding MaxAlbumArtSize, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Style="{StaticResource RowLabel}" Text="Max album-art size (px)"/></DockPanel></Border>
      </StackPanel>

      <!-- special audio decode: green bulbs (color-coded category) -->
      <StackPanel>
        <StackPanel.Resources>
          <Color x:Key="LampCore">#EAFFF1</Color><Color x:Key="LampLight">#9FE9B8</Color><Color x:Key="LampBase">#3FB877</Color>
          <Color x:Key="LampDark">#1E5E38</Color><Color x:Key="LampEdge">#06210F</Color><Color x:Key="LampHalo">#5CCB8B</Color>
          <Color x:Key="LampCapCore">#B8EFFBEF</Color><Color x:Key="LampCapMid">#5A7AD89A</Color><Color x:Key="LampCapEdge">#005CCB8B</Color>
        </StackPanel.Resources>
        <TextBlock Style="{StaticResource Sec}" Text="HDCD"/>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding DetectHdcd}"/><TextBlock Style="{StaticResource RowLabel}" Text="Detect HDCD"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding DecodeHdcd}"/><TextBlock Style="{StaticResource RowLabel}" Text="Decode HDCD to high-resolution"/></DockPanel></Border>
        <Border Style="{StaticResource Row}"><DockPanel><ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding DecodeHdcdTo24}"/><TextBlock Style="{StaticResource RowLabel}" Text="Decode HDCD to 24-bit"/></DockPanel></Border>
      </StackPanel>

      <TextBlock Style="{StaticResource Sec}" Text="DIAGNOSTICS"/>
      <Border Style="{StaticResource Row}" ToolTip="A privacy-safe log of what the app does this run - phases, counts, timings, and full error detail if something fails - with no album/artist/track names, and paths scrubbed of your user name and folders. Open the folder to attach it to a bug report.">
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="Open log folder" Command="{Binding OpenLogFolderCommand}" Padding="12,6" VerticalAlignment="Center"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Style="{StaticResource RowLabel}" Text="Diagnostic log (privacy-safe)"/>
            <TextBlock Text="{Binding LogPath}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Muted}" TextTrimming="CharacterEllipsis" MaxWidth="470"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <TextBlock Margin="2,22,0,0" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"
                 Text="These write straight to the live configuration. The remaining sections (Metadata, Encoding &amp; Formats with the codec editor, Ripper &amp; Drives) and settings persistence are the next increments."/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
