<UserControl x:Class="CUETools.Wpf.Views.ConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:CUETools.Wpf.Controls">
  <Grid Background="{DynamicResource Ground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- source + format bar -->
    <Border Grid.Row="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,11">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Left" Text="Source" Foreground="{DynamicResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
        <Button DockPanel.Dock="Right" Content="Convert" Command="{Binding ConvertCommand}" Style="{StaticResource Accent}" Padding="16,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
        <ComboBox DockPanel.Dock="Right" Width="90" VerticalAlignment="Center" Margin="8,0,0,0"
                  ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat, Mode=TwoWay}"/>
        <TextBlock DockPanel.Dock="Right" Text="to" Foreground="{DynamicResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
        <Button DockPanel.Dock="Right" Content="Folder..." Command="{Binding BrowseFolderCommand}" Padding="12,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Content="File..." Command="{Binding BrowseFileCommand}" Padding="12,7" VerticalAlignment="Center"/>
        <Border Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
          <TextBlock Text="{Binding SourcePath}" Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
        </Border>
      </DockPanel>
    </Border>

    <!-- body -->
    <Grid Grid.Row="1">
      <!-- instruction state -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520"
                  Visibility="{Binding HasResult, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
        <TextBlock Text="Convert a rip you already have" FontFamily="{StaticResource Serif}" FontSize="22" Foreground="{DynamicResource Muted}" HorizontalAlignment="Center"/>
        <TextBlock TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" FontSize="12.5" Margin="0,8,0,0"
                   Text="Pick a .cue, an album folder, or a file with an embedded cue, choose an output format, and CUETools re-encodes every track. Only formats with a working encoder in this build are offered."/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
          <TextBlock Text="Output:" Foreground="{DynamicResource Muted}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <Button Content="Choose folder..." Command="{Binding BrowseOutputCommand}" Padding="12,6"/>
          <TextBlock Text="{Binding OutputDir}" Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>
        <TextBlock Text="(default: Music\CUETools\Artist - Album)" Foreground="{DynamicResource Muted}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,6,0,0"/>

        <!-- educational: what the chosen codec actually does -->
        <Border Background="{DynamicResource Glass}" BorderBrush="{DynamicResource GlassLine}" BorderThickness="1" CornerRadius="11" Padding="16,13" Margin="0,22,0,0" MinWidth="520">
          <ctl:CodecScope Height="118" Codec="{Binding SelectedFormat, Mode=OneWay}" Active="{Binding IsBusy, Mode=OneWay}"/>
        </Border>
      </StackPanel>

      <!-- result state -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="620"
                  Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}">
        <Grid Width="70" Height="70" HorizontalAlignment="Center" Margin="0,0,16,0">
          <Ellipse Fill="{StaticResource Good}"><Ellipse.Effect><DropShadowEffect Color="#5CCB8B" BlurRadius="24" ShadowDepth="0" Opacity="0.85"/></Ellipse.Effect></Ellipse>
          <Ellipse Width="52" Height="52" Stroke="{DynamicResource Ground}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
        </Grid>
        <TextBlock Text="Conversion complete" FontFamily="{StaticResource Serif}" FontSize="22" Foreground="{DynamicResource Ink}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
        <TextBlock Text="{Binding ResultText}" Foreground="{DynamicResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11.5" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
      </StackPanel>
    </Grid>

    <!-- progress bar -->
    <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource InkDim}" FontSize="12" TextTrimming="CharacterEllipsis"/>
        <ProgressBar Height="4" Margin="0,7,0,0" Minimum="0" Maximum="1" Value="{Binding Progress, Mode=OneWay}"
                     Background="{DynamicResource Glass}" Foreground="{StaticResource Teal}" BorderThickness="0"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
