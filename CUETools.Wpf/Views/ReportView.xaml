<UserControl x:Class="CUETools.Wpf.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{StaticResource Ground}">

    <!-- empty state -->
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding HasReport, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
      <TextBlock Text="No report yet" FontFamily="{StaticResource Serif}" FontSize="23" Foreground="{StaticResource Muted}" HorizontalAlignment="Center"/>
      <TextBlock Text="Run a Verify or Rip on the Rip page and the accuracy certificate lands here." Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,7,0,0" HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- certificate -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding HasReport, Converter={StaticResource BoolVis}}">
      <Border MaxWidth="720" Margin="24,22" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="14" Padding="6">
        <Border BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="10" Padding="30,26">
          <StackPanel>

            <!-- wax seal -->
            <Grid Width="78" Height="78" HorizontalAlignment="Center" Margin="0,0,0,14">
              <Ellipse>
                <Ellipse.Style>
                  <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="{StaticResource Amber}"/>
                    <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#E9A63F" BlurRadius="26" ShadowDepth="0" Opacity="0.8"/></Setter.Value></Setter>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Confirmed}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource Good}"/>
                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#5CCB8B" BlurRadius="26" ShadowDepth="0" Opacity="0.85"/></Setter.Value></Setter>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Ellipse.Style>
              </Ellipse>
              <Ellipse Width="58" Height="58" Stroke="{StaticResource Ground}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
              <Ellipse Width="30" Height="30" Stroke="{StaticResource Ground}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
            </Grid>

            <TextBlock Text="{Binding Headline}" FontFamily="{StaticResource Serif}" FontSize="15" HorizontalAlignment="Center"
                       Foreground="{StaticResource Muted}" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Album}" FontFamily="{StaticResource Serif}" FontSize="27" Foreground="{StaticResource Ink}"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding Artist}" FontSize="14" Foreground="{StaticResource Ink}" Opacity="0.85"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0"/>
            <TextBlock Text="{Binding Subhead}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Muted}"
                       HorizontalAlignment="Center" Margin="0,7,0,0"/>

            <!-- confidence stats -->
            <UniformGrid Columns="2" Margin="0,20,0,0">
              <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="9" Padding="16,13" Margin="0,0,7,0">
                <StackPanel>
                  <TextBlock Text="ACCURATERIP" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                  <TextBlock Text="{Binding ArText}" FontFamily="{StaticResource Serif}" FontSize="19" Foreground="{StaticResource Teal}" Margin="0,2,0,0"/>
                </StackPanel>
              </Border>
              <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="9" Padding="16,13" Margin="7,0,0,0">
                <StackPanel>
                  <TextBlock Text="CUETOOLS DB" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                  <TextBlock Text="{Binding CtdbText}" FontFamily="{StaticResource Serif}" FontSize="19" Foreground="{StaticResource Teal}" Margin="0,2,0,0"/>
                </StackPanel>
              </Border>
            </UniformGrid>

            <!-- full rip log (selectable) -->
            <TextBlock Text="RIP LOG" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource Muted}" Margin="2,20,0,7"/>
            <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="8" Padding="14,12">
              <TextBox Text="{Binding LogBody, Mode=OneWay}" IsReadOnly="True" IsTabStop="False" BorderThickness="0"
                       Background="Transparent" Foreground="{StaticResource Ink}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                       TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"/>
            </Border>

            <!-- tamper-evident footer -->
            <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource Teal}" BorderThickness="1" CornerRadius="8" Padding="14,11" Margin="0,14,0,0">
              <StackPanel>
                <DockPanel>
                  <Ellipse DockPanel.Dock="Left" Width="12" Height="12" Fill="{StaticResource Teal}" Margin="0,1,10,0" VerticalAlignment="Top">
                    <Ellipse.Effect><DropShadowEffect Color="#34CFC0" BlurRadius="9" ShadowDepth="0"/></Ellipse.Effect>
                  </Ellipse>
                  <TextBlock Text="{Binding IntegrityLine}" Foreground="{StaticResource Ink}" FontSize="12" TextWrapping="Wrap"/>
                </DockPanel>
                <TextBlock Text="{Binding DigestFooter}" Foreground="{StaticResource Muted}" FontFamily="{StaticResource Mono}" FontSize="10.5" TextWrapping="Wrap" Margin="22,7,0,0"/>
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
