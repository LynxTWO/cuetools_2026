<Window x:Class="CUETools.Wpf.Views.EncoderSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encoder settings" Width="520" SizeToContent="Height" MaxHeight="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Ground}" Foreground="{DynamicResource Ink}"
        WindowStyle="ToolWindow" ShowInTaskbar="False">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20,16,20,18">
      <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Serif}" FontSize="20" Foreground="{DynamicResource Ink}"/>
      <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource Muted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0"/>

      <!-- TYPE: only for two-faced formats (wma = WMA Lossless vs Standard; m4a = ALAC vs AAC).
           Switching persists the choice, moves the format between the lossless/lossy lists, and
           rebuilds this dialog around the other encoder. -->
      <StackPanel Visibility="{Binding HasTypeChoice, Converter={StaticResource BoolVis}}">
        <TextBlock Text="TYPE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Teal}" Margin="0,14,0,6"/>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="12,9">
          <StackPanel Orientation="Horizontal">
            <RadioButton Content="Lossless" IsChecked="{Binding TypeLossless}" GroupName="fmtType" Foreground="{DynamicResource Ink}"
                         ToolTip="Bit-exact archival encoding (WMA Lossless / ALAC). The format moves to the lossless list."/>
            <RadioButton Content="Lossy" IsChecked="{Binding TypeLossy}" GroupName="fmtType" Margin="22,0,0,0" Foreground="{DynamicResource Ink}"
                         ToolTip="Perceptual encoding at the quality mode below (WMA Standard / AAC). The format moves to the lossy list."/>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- COMMON: the compression / quality mode -->
      <StackPanel Visibility="{Binding HasModes, Converter={StaticResource BoolVis}}">
        <TextBlock Text="COMPRESSION / QUALITY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Teal}" Margin="0,16,0,6"/>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="12,10">
          <StackPanel>
            <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" Width="180" HorizontalAlignment="Left"
                      ToolTip="{Binding ModeHint}"/>
            <TextBlock Text="{Binding ModeHint}" Foreground="{DynamicResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ADVANCED: everything the encoder exposes, straight from the codec itself -->
      <StackPanel Visibility="{Binding HasAdvanced, Converter={StaticResource BoolVis}}">
        <TextBlock Text="ADVANCED" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Amber}" Margin="0,16,0,6"/>
        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="12,4">
          <ItemsControl ItemsSource="{Binding Advanced}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <DockPanel Margin="0,7" ToolTip="{Binding Tooltip}" LastChildFill="False">
                  <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" Foreground="{DynamicResource InkDim}" FontSize="12.5"
                             VerticalAlignment="Center" MinWidth="150"/>
                  <ToggleButton DockPanel.Dock="Right" Style="{StaticResource Switch}" IsChecked="{Binding BoolValue}"
                                Visibility="{Binding IsBool, Converter={StaticResource BoolVis}}"/>
                  <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding EnumValues}" SelectedItem="{Binding TextValue}" MinWidth="130"
                            Visibility="{Binding IsEnum, Converter={StaticResource BoolVis}}"/>
                  <TextBox DockPanel.Dock="Right" Text="{Binding TextValue, UpdateSourceTrigger=LostFocus}" MinWidth="220" MaxWidth="290"
                           Visibility="{Binding IsText, Converter={StaticResource BoolVis}}"
                           Background="{DynamicResource Glass}" Foreground="{DynamicResource Ink}" BorderBrush="{DynamicResource Line}"/>
                </DockPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
      </StackPanel>

      <DockPanel Margin="0,16,0,0" LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="Hover any setting for what it does." Foreground="{DynamicResource Muted}" FontSize="10.5" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Content="Close" Padding="18,6" Click="Close_Click"/>
      </DockPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
