<UserControl x:Class="CUETools.Wpf.Views.VerifyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{StaticResource Ground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- source bar -->
    <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="16,11">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Left" Text="Source" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
        <Button DockPanel.Dock="Right" Content="Verify" Command="{Binding VerifyCommand}" Padding="16,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Content="Folder..." Command="{Binding BrowseFolderCommand}" Padding="12,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Content="File..." Command="{Binding BrowseFileCommand}" Padding="12,7" VerticalAlignment="Center"/>
        <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
          <TextBlock Text="{Binding SourcePath}" Foreground="{StaticResource InkDim}" FontFamily="{StaticResource Mono}" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
        </Border>
      </DockPanel>
    </Border>

    <!-- body -->
    <Grid Grid.Row="1">

      <!-- instruction state -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520"
                  Visibility="{Binding HasResult, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
        <TextBlock Text="Verify a rip you already have" FontFamily="{StaticResource Serif}" FontSize="22" Foreground="{StaticResource Muted}" HorizontalAlignment="Center"/>
        <TextBlock TextAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,8,0,0"
                   Text="Pick a .cue, an album folder, or a file with an embedded cue. CUETools checks every track against AccurateRip and the CUETools database. If a track has errors that CTDB can recover, Repair rebuilds it from parity."/>
      </StackPanel>

      <!-- result state -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}">
        <StackPanel Margin="24,22" MaxWidth="720" HorizontalAlignment="Left">
          <TextBlock Text="{Binding Album}" FontFamily="{StaticResource Serif}" FontSize="25" Foreground="{StaticResource Ink}" TextWrapping="Wrap"/>

          <UniformGrid Columns="2" Margin="0,18,0,0">
            <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="9" Padding="16,13" Margin="0,0,7,0">
              <StackPanel>
                <TextBlock Text="ACCURATERIP" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                <TextBlock Text="{Binding ArText}" FontFamily="{StaticResource Serif}" FontSize="18" Foreground="{StaticResource Teal}" Margin="0,2,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Background="{StaticResource Glass}" BorderBrush="{StaticResource GlassLine}" BorderThickness="1" CornerRadius="9" Padding="16,13" Margin="7,0,0,0">
              <StackPanel>
                <TextBlock Text="CUETOOLS DB" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                <TextBlock Text="{Binding CtdbText}" FontFamily="{StaticResource Serif}" FontSize="18" Foreground="{StaticResource Teal}" Margin="0,2,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </UniformGrid>

          <!-- repair banner: only when there are recoverable errors -->
          <Border Margin="0,16,0,0" CornerRadius="9" Padding="16,14" BorderThickness="1"
                  Visibility="{Binding CanRepair, Converter={StaticResource BoolVis}}"
                  Background="{StaticResource Glass}" BorderBrush="{StaticResource Amber}">
            <DockPanel LastChildFill="True">
              <Ellipse DockPanel.Dock="Left" Width="13" Height="13" Fill="{StaticResource Amber}" VerticalAlignment="Top" Margin="0,2,12,0">
                <Ellipse.Effect><DropShadowEffect Color="#E9A63F" BlurRadius="9" ShadowDepth="0"/></Ellipse.Effect>
              </Ellipse>
              <Button DockPanel.Dock="Right" Content="Repair" Command="{Binding RepairCommand}" Padding="18,8" VerticalAlignment="Center" Margin="12,0,0,0"/>
              <StackPanel>
                <TextBlock Text="Errors found - recoverable from CTDB parity" Foreground="{StaticResource Ink}" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="Repair rewrites the affected audio in place. Back up the rip first if you want to keep the original." Foreground="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
              </StackPanel>
            </DockPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- action / progress bar -->
    <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource InkDim}" FontSize="12" TextTrimming="CharacterEllipsis"/>
          <ProgressBar Height="4" Margin="0,7,12,0" Minimum="0" Maximum="1" Value="{Binding Progress, Mode=OneWay}"
                       Background="{StaticResource Glass}" Foreground="{StaticResource Teal}" BorderThickness="0"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
