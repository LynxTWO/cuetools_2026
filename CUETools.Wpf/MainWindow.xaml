<Window x:Class="CUETools.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CUETools 2026" Height="760" Width="1200"
        Background="{DynamicResource Ground}" WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">
  <Window.Resources>
    <CollectionViewSource x:Key="NavPages" Source="{Binding Pages}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Group"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- faceplate -->
    <Border Grid.Row="0" Background="{DynamicResource Face}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,10">
      <DockPanel LastChildFill="False">
        <Ellipse DockPanel.Dock="Left" Width="8" Height="8" Fill="{StaticResource Teal}" VerticalAlignment="Center" Margin="0,0,11,0"/>
        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock FontFamily="{StaticResource Serif}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Ink}">
            CUE<Run Foreground="{StaticResource Teal}">Tools</Run>
          </TextBlock>
          <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Muted}" Text="2026 - rip - verify - repair - convert"/>
        </StackPanel>
        <!-- theme toggle (rightmost) -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
          <TextBlock Text="LIGHT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,9,0"/>
          <ToggleButton Style="{StaticResource Switch}" IsChecked="{Binding IsLightTheme, Mode=TwoWay}" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontFamily="{StaticResource Mono}" FontSize="11"
                   Foreground="{DynamicResource InkDim}" Text="{Binding DriveStatus}"/>
      </DockPanel>
    </Border>

    <!-- body: nav + content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="214"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{DynamicResource Bar}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
        <ListBox ItemsSource="{Binding Source={StaticResource NavPages}}"
                 SelectedItem="{Binding CurrentPage, Mode=TwoWay}"
                 Background="Transparent" BorderThickness="0" Padding="8,8"
                 ItemContainerStyle="{StaticResource NavItem}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Title}" FontSize="13"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" FontSize="9" FontWeight="Bold"
                             Foreground="{DynamicResource Muted}" Margin="11,13,0,4"/>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
        </ListBox>
      </Border>

      <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" ContentTemplateSelector="{StaticResource PageSelector}"/>
    </Grid>
  </Grid>
</Window>
